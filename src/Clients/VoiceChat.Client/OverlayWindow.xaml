<Window x:Class="VoiceChat.Client.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hop Overlay" Height="72" Width="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Normal ikon butonu -->
        <Style x:Key="OverlayBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="10" Background="Transparent" Padding="0,6,0,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Dış çerçeve: neon mor parıldama -->
    <Border Margin="4" CornerRadius="18"
            BorderBrush="#558B5CF6" BorderThickness="1"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#7C3AED" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <!-- Frosted glass iç arka plan -->
        <Border CornerRadius="17" Background="#CC0D0D1A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Sürükleme tutamacı -->
                    <ColumnDefinition Width="14"/>
                    <!-- Sol: Hop brand + oda adı -->
                    <ColumnDefinition Width="80"/>
                    <!-- Ayraç -->
                    <ColumnDefinition Width="1"/>
                    <!-- Butonlar -->
                    <ColumnDefinition Width="*"/>
                    <!-- Disconnect -->
                    <ColumnDefinition Width="58"/>
                </Grid.ColumnDefinitions>

                <!-- Sürükleme noktaları -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="5,0,0,0">
                    <WrapPanel Width="7" Height="20" Orientation="Horizontal">
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,1.5,0"/>
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,0,0"/>
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,1.5,0"/>
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,0,0"/>
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,1.5,0"/>
                        <Ellipse Width="2.5" Height="2.5" Fill="#55FFFFFF" Margin="0,1.5,0,0"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Sol bilgi: Hop + oda adı -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,6,0">
                    <TextBlock Text="Hop" FontWeight="Bold" FontSize="13"
                               Foreground="#C4B5FD" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="6" Height="6" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="txtRoomName" Text="Genel" FontSize="9"
                                   Foreground="#99FFFFFF" FontFamily="Segoe UI"
                                   TextTrimming="CharacterEllipsis" MaxWidth="62"/>
                    </StackPanel>
                </StackPanel>

                <!-- Dikey ayraç çizgisi -->
                <Rectangle Grid.Column="2" Width="1" Fill="#22FFFFFF" Margin="0,10"/>

                <!-- Butonlar: Mic, Deafen, Restore -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Mikrofon -->
                    <Button Style="{StaticResource OverlayBtn}" Click="MuteButton_Click"
                            ToolTip="Mikrofonu Sustur / Aç">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="18" Height="18" HorizontalAlignment="Center">
                                <Path x:Name="micPath" Fill="#FFFFFF" Stretch="Uniform"
                                      Data="M 12 4 C 10.3 4 9 5.3 9 7 L 9 13 C 9 14.7 10.3 16 12 16 C 13.7 16 15 14.7 15 13 L 15 7 C 15 5.3 13.7 4 12 4 Z M 18 11 L 17 11 C 17 13.5 14.9 15.5 12.3 15.5 C 9.8 15.5 7.7 13.5 7.7 11 L 6.7 11 C 6.7 13.8 8.7 16.1 11.3 16.4 L 11.3 19 L 12.7 19 L 12.7 16.4 C 15.3 16.1 17.3 13.8 17.3 11 Z"/>
                                <Line x:Name="micSlash" X1="2" Y1="16" X2="16" Y2="2"
                                      Stroke="#EF4444" StrokeThickness="2.5" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="micLabel" Text="Mikrofon" FontSize="8"
                                       Foreground="#88FFFFFF" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Kulaklık / Deafen -->
                    <Button Style="{StaticResource OverlayBtn}" Click="DeafenButton_Click"
                            ToolTip="Sağırlaştır / Aç">
                        <StackPanel HorizontalAlignment="Center">
                            <Grid Width="18" Height="18" HorizontalAlignment="Center">
                                <Path x:Name="deafenPath" Fill="#FFFFFF" Stretch="Uniform"
                                      Data="M 12 3 C 7 3 3 7 3 12 L 3 15 C 3 16.7 4.3 18 6 18 L 7 18 C 8.1 18 9 17.1 9 16 L 9 12 C 9 10.9 8.1 10 7 10 L 5 10 C 5 7.2 8.1 5 12 5 C 15.9 5 19 7.2 19 10 L 17 10 C 15.9 10 15 10.9 15 12 L 15 16 C 15 17.1 15.9 18 17 18 L 18 18 C 19.7 18 21 16.7 21 15 L 21 12 C 21 7 17 3 12 3 Z"/>
                                <Line x:Name="deafenSlash" X1="2" Y1="16" X2="16" Y2="2"
                                      Stroke="#EF4444" StrokeThickness="2.5" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="deafenLabel" Text="Ses" FontSize="8"
                                       Foreground="#88FFFFFF" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Büyüt / Restore -->
                    <Button Style="{StaticResource OverlayBtn}" Click="RestoreButton_Click"
                            ToolTip="Uygulamayı Büyüt">
                        <StackPanel HorizontalAlignment="Center">
                            <Path Fill="#A5B4FC" Stretch="Uniform" Width="16" Height="16"
                                  HorizontalAlignment="Center"
                                  Data="M 3 3 L 9 3 L 9 5 L 5 5 L 5 9 L 3 9 Z M 15 3 L 21 3 L 21 9 L 19 9 L 19 5 L 15 5 Z M 3 15 L 5 15 L 5 19 L 9 19 L 9 21 L 3 21 Z M 19 15 L 21 15 L 21 21 L 15 21 L 15 19 L 19 19 Z"/>
                            <TextBlock Text="Büyüt" FontSize="8"
                                       Foreground="#88FFFFFF" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Disconnect: yuvarlak kırmızı buton, sadece telefon ikonu -->
                <Button Grid.Column="4" Click="DisconnectButton_Click"
                        ToolTip="Bağlantıyı Kes"
                        Cursor="Hand" Focusable="False"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="4,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" CornerRadius="20" Width="40" Height="40"
                                    Background="#EF4444">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#DC2626"/>
                                    <Setter TargetName="bg" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#EF4444" BlurRadius="12"
                                                              ShadowDepth="0" Opacity="0.8"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#B91C1C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <!-- Telefonu kapat ikonu (çevrilmiş ahize) -->
                    <Path Fill="White" Width="20" Height="20" Stretch="Uniform"
                          RenderTransformOrigin="0.5,0.5"
                          Data="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.3 21 3 13.7 3 4.5c0-.6.4-1 1-1H8c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z">
                        <Path.RenderTransform>
                            <RotateTransform Angle="135"/>
                        </Path.RenderTransform>
                    </Path>
                </Button>

            </Grid>
        </Border>
    </Border>
</Window>

